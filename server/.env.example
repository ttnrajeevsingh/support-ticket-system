# ── Supabase PostgreSQL connection strings ─────────────────────────────────────
#
# Both URLs use the session-mode pooler (port 5432) on the pooler host.
# This is required when the transaction pooler (port 6543) is blocked by network policy.
#
# Get from: Supabase dashboard -> Project Settings -> Database -> Connection string
#   - Session mode / Connection pooling (port 5432) -> DATABASE_URL
#   - Same URL -> DIRECT_URL (used by prisma migrate)
#
DATABASE_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Express server port
PORT=3001

# Next.js client origin (for CORS)
CLIENT_ORIGIN=http://localhost:3000

# Node environment
NODE_ENV=development
